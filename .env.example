# Enzan — Environment Variables
# Copy this file to .env and fill in your values.

# ─── Cosmos DB ────────────────────────────────────────────────────────────────
# Endpoint and write key for the Cosmos DB account backing Enzan.
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your_cosmos_key_here
COSMOS_DB_NAME=enzan-db

# ─── Azure OpenAI (embeddings) ────────────────────────────────────────────────
AOAI_ENDPOINT=https://your-aoai-instance.openai.azure.com/
AOAI_KEY=your_aoai_key_here
AOAI_EMBED_DEPLOYMENT=text-embedding-3-large

# ─── Enzan Server ─────────────────────────────────────────────────────────────
# Transport: "stdio" (local dev / Cursor) or "http" (hosted / multi-tenant)
ENZAN_TRANSPORT=stdio
ENZAN_PORT=3000

# Admin key for tenant provisioning endpoint (POST /tenants).
# Only needed when ENZAN_TRANSPORT=http.
ENZAN_ADMIN_KEY=change_me_in_production

# ─── Optional: embeddings override ───────────────────────────────────────────
# AOAI_EMBED_DIMS=3072
# AOAI_API_VERSION=2024-02-01
